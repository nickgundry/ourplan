# Copy to .env.local for local development
# Add each as a Vercel Environment Variable for production

# Postgres — from Supabase: Project Settings → Database → Connection string
# Use Transaction (pooled) for POSTGRES_URL, Session for POSTGRES_URL_NON_POOLING
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# Auth
JWT_SECRET=generate-a-long-random-string-here

# Twilio — create a free account at twilio.com
# Used for SMS alert fan-out
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+15550000000

# Resend — for password reset emails (resend.com — free tier: 100 emails/day)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# Google OAuth — from console.cloud.google.com
# Create an OAuth 2.0 Client ID → iOS → bundle com.prepared.app
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com

# Apple Sign In — from developer.apple.com
# Enable "Sign in with Apple" in your App ID
APPLE_BUNDLE_ID=com.prepared.app

# App base URL
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app
